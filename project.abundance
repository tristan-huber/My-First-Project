                  "interpreterVersion": 1,
                  "code": "/**\n * Extracts the ruling lines from a ruled surface.\n *\n * Input must be an Assembly containing a single replicad.Face — typically the\n * side face of a ruled loft. The atom samples `numRulings + 1` straight-line\n * generators across the surface and returns them as 3D wires for visual\n * confirmation. A downstream \"Develop\" atom will reuse this sampling to flatten\n * the surface into a 2D pattern.\n *\n *   rulingAxis === \"U\"  → each ruling sweeps U from uMin..uMax with V fixed;\n *                          rulings step in V.\n *   rulingAxis === \"V\"  → each ruling sweeps V from vMin..vMax with U fixed;\n *                          rulings step in U.\n *   rulingAxis === \"auto\" → pick the parametric axis whose interior iso-curves\n *                          are (within tolerance) straight lines. Ties prefer V\n *                          to match replicad's `ruled: true` loft convention.\n */\nfunction run(\n  surface: Assembly,\n  numRulings: number = 24,\n  rulingAxis: string = \"auto\",\n  boundarySamples: number = 256,\n): Assembly {\n  // ── Step 1: Validate input is a single Face ───────────────────────────────\n  if (!surface || !surface.isLeaf || !surface.isLeaf()) {\n    throw new Error(\n      \"Develop rulings: input must be an Assembly with exactly one leaf \" +\n      \"(the ruled surface as a replicad.Face).\",\n    );\n  }\n  const face = surface.geometry as any;\n  if (!(face instanceof replicad.Face)) {\n    throw new Error(\n      \"Develop rulings: input geometry must be a replicad.Face from a ruled \" +\n      \"loft; got \" +\n      (face && face.constructor ? face.constructor.name : typeof face),\n    );\n  }\n  if (!Number.isFinite(numRulings) || numRulings < 1) {\n    throw new Error(\"Develop rulings: numRulings must be a positive integer.\");\n  }\n  const n = Math.max(1, Math.floor(numRulings));\n  const boundaryN = Math.max(8, Math.floor(boundarySamples));\n\n  const { uMin, uMax, vMin, vMax } = face.UVBounds;\n\n  // IMPORTANT: replicad's face.pointOnSurface(u, v) takes NORMALISED\n  // parameters in [0, 1] (internally it does uMin + u*(uMax-uMin)), while\n  // face.UVBounds returns ABSOLUTE OCCT parameter values. Sampling with\n  // absolute values directly causes the ruling endpoints to land far\n  // outside the actual surface (apparent as rulings extending past the\n  // real face edges, especially on cones).\n  const uSpan = uMax - uMin;\n  const vSpan = vMax - vMin;\n  const sampleTuple = (uAbs: number, vAbs: number): [number, number, number] => {\n    const uN = uSpan === 0 ? 0 : (uAbs - uMin) / uSpan;\n    const vN = vSpan === 0 ? 0 : (vAbs - vMin) / vSpan;\n    const p = face.pointOnSurface(uN, vN);\n    return [p.x, p.y, p.z];\n  };\n\n  // ── Step 2: Decide which parametric axis is the ruling direction ──────────\n  // An iso-curve sample at parameters (p0, pm, p1) is \"straight\" when the\n  // perpendicular distance from the midpoint to the chord is negligible\n  // relative to the chord length.\n  const STRAIGHT_TOL = 1e-4;\n  const isStraightAlong = (axis: \"U\" | \"V\"): boolean => {\n    const cross =\n      axis === \"U\" ? vMin + 0.5 * (vMax - vMin) : uMin + 0.5 * (uMax - uMin);\n    const a = axis === \"U\" ? uMin : vMin;\n    const b = axis === \"U\" ? uMax : vMax;\n    const get = (t: number) =>\n      axis === \"U\" ? sampleTuple(t, cross) : sampleTuple(cross, t);\n    const p0 = get(a);\n    const pm = get(0.5 * (a + b));\n    const p1 = get(b);\n    const dx = p1[0] - p0[0],\n      dy = p1[1] - p0[1],\n      dz = p1[2] - p0[2];\n    const chord = Math.hypot(dx, dy, dz);\n    if (chord === 0) return false;\n    const tx = pm[0] - p0[0],\n      ty = pm[1] - p0[1],\n      tz = pm[2] - p0[2];\n    // |(p1-p0) × (pm-p0)| / |p1-p0| = perpendicular distance.\n    const cx = dy * tz - dz * ty;\n    const cy = dz * tx - dx * tz;\n    const cz = dx * ty - dy * tx;\n    const perp = Math.hypot(cx, cy, cz) / chord;\n    return perp / chord < STRAIGHT_TOL;\n  };\n\n  let axis: \"U\" | \"V\";\n  if (rulingAxis === \"U\" || rulingAxis === \"V\") {\n    axis = rulingAxis;\n  } else if (rulingAxis === \"auto\") {\n    const vStraight = isStraightAlong(\"V\");\n    const uStraight = isStraightAlong(\"U\");\n    if (vStraight) axis = \"V\";\n    else if (uStraight) axis = \"U\";\n    else\n      throw new Error(\n        \"Develop rulings: auto-detect failed — surface is not straight along \" +\n        \"either parametric axis (it is not a ruled surface, or the trimmed \" +\n        \"region is curved on both axes). Override with rulingAxis: 'U' or 'V'.\",\n      );\n  } else {\n    throw new Error(\n      'Develop rulings: rulingAxis must be \"auto\", \"U\", or \"V\"; got ' +\n      JSON.stringify(rulingAxis),\n    );\n  }\n\n  // ── Step 3: Sample the trimmed boundary in UV space ──────────────────────\n  // face.UVBounds is the bbox of the outerWire in UV space — it can be looser\n  // than the actual trimmed region whenever the wire is not axis-aligned in\n  // UV (common for lofts and any face on a periodic surface). A loft's\n  // underlying parametric surface also extends past the face — e.g. a conical\n  // loft continues toward its apex beyond the bottom circle. We follow\n  // face.outerWire() in UV space and use it to clip each ruling to the real\n  // trimmed region.\n  const outerWire = face.clone().outerWire();\n  type T2 = [number, number];\n  const uvBoundary: T2[] = [];\n  for (let i = 0; i < boundaryN; i++) {\n    const t = i / boundaryN;\n    const p3d = outerWire.pointAt(t);\n    const uv = face.uvCoordinates(p3d);\n    uvBoundary.push([uv[0], uv[1]]);\n  }\n\n  // axis === \"V\": rulings sweep V; cross-axis is U  → crossIdx=0, alongIdx=1\n  // axis === \"U\": rulings sweep U; cross-axis is V  → crossIdx=1, alongIdx=0\n  const crossIdx = axis === \"V\" ? 0 : 1;\n  const alongIdx = 1 - crossIdx;\n\n  let crossMinActual = Infinity;\n  let crossMaxActual = -Infinity;\n  for (const uv of uvBoundary) {\n    if (uv[crossIdx] < crossMinActual) crossMinActual = uv[crossIdx];\n    if (uv[crossIdx] > crossMaxActual) crossMaxActual = uv[crossIdx];\n  }\n  const crossSpan = crossMaxActual - crossMinActual;\n  if (!(crossSpan > 0)) {\n    throw new Error(\n      \"Develop rulings: trimmed boundary has zero extent on the cross-axis.\",\n    );\n  }\n\n  // Intersect the iso-line \"cross-axis = crossParam\" with the closed UV\n  // polyline and return [alongMin, alongMax].\n  const rulingRange = (crossParam: number): [number, number] => {\n    const hits: number[] = [];\n    const N = uvBoundary.length;\n    for (let j = 0; j < N; j++) {\n      const a = uvBoundary[j];\n      const b = uvBoundary[(j + 1) % N];\n      const aC = a[crossIdx];\n      const bC = b[crossIdx];\n      if (aC === bC) continue;\n      // Skip seam wraparounds on periodic surfaces.\n      if (Math.abs(bC - aC) > 0.5 * crossSpan) continue;\n      const straddles =\n        (aC <= crossParam && bC > crossParam) ||\n        (bC <= crossParam && aC > crossParam);\n      if (!straddles) continue;\n      const t = (crossParam - aC) / (bC - aC);\n      hits.push(a[alongIdx] + t * (b[alongIdx] - a[alongIdx]));\n    }\n    if (hits.length < 2) {\n      throw new Error(\n        `Develop rulings: cross-axis ${axis === \"V\" ? \"U\" : \"V\"}=` +\n        `${crossParam.toFixed(4)} intersects the trimmed boundary at ` +\n        `${hits.length} point(s) (expected ≥2). Increase boundarySamples or ` +\n        `check for inner holes.`,\n      );\n    }\n    hits.sort((a, b) => a - b);\n    return [hits[0], hits[hits.length - 1]];\n  };\n\n  // ── Step 4: Build n+1 ruling edges, clipped to the outerWire polygon ─────\n  const rulings: Assembly[] = [];\n  for (let i = 0; i <= n; i++) {\n    const t = i / n;\n    let crossParam = crossMinActual + t * crossSpan;\n    // Nudge the extremes a hair inward so the iso-line genuinely crosses\n    // the polygon (it may be tangent at the extreme cross values).\n    if (i === 0) crossParam += crossSpan * 1e-6;\n    if (i === n) crossParam -= crossSpan * 1e-6;\n    const [alongLow, alongHigh] = rulingRange(crossParam);\n    const startU = axis === \"V\" ? crossParam : alongLow;\n    const startV = axis === \"V\" ? alongLow : crossParam;\n    const endU = axis === \"V\" ? crossParam : alongHigh;\n    const endV = axis === \"V\" ? alongHigh : crossParam;\n    const start = sampleTuple(startU, startV);\n    const end = sampleTuple(endU, endV);\n    const edge = replicad.makeLine(start, end);\n    // The framework rejects bare Edges (see code.ts); wrap with assembleWire\n    // so each ruling round-trips as a Wire leaf.\n    const wire = replicad.assembleWire([edge]);\n    rulings.push(\n      new Assembly({\n        geometry: wire,\n        color: \"#e07b00\",\n        tags: [\"ruling\"],\n      }),\n    );\n  }\n\n  return new Assembly({\n    geometry: rulings,\n    color: \"#e07b00\",\n    tags: [\"rulings\", \"ruling-axis:\" + axis],\n  });\n}\n",
                  "compiledCode": "\"use strict\";\n/**\n * Extracts the ruling lines from a ruled surface.\n *\n * Input must be an Assembly containing a single replicad.Face — typically the\n * side face of a ruled loft. The atom samples `numRulings + 1` straight-line\n * generators across the surface and returns them as 3D wires for visual\n * confirmation. A downstream \"Develop\" atom will reuse this sampling to flatten\n * the surface into a 2D pattern.\n *\n *   rulingAxis === \"U\"  → each ruling sweeps U from uMin..uMax with V fixed;\n *                          rulings step in V.\n *   rulingAxis === \"V\"  → each ruling sweeps V from vMin..vMax with U fixed;\n *                          rulings step in U.\n *   rulingAxis === \"auto\" → pick the parametric axis whose interior iso-curves\n *                          are (within tolerance) straight lines. Ties prefer V\n *                          to match replicad's `ruled: true` loft convention.\n */\nfunction run(surface, numRulings = 24, rulingAxis = \"auto\", boundarySamples = 256) {\n    // ── Step 1: Validate input is a single Face ───────────────────────────────\n    if (!surface || !surface.isLeaf || !surface.isLeaf()) {\n        throw new Error(\"Develop rulings: input must be an Assembly with exactly one leaf \" +\n            \"(the ruled surface as a replicad.Face).\");\n    }\n    const face = surface.geometry;\n    if (!(face instanceof replicad.Face)) {\n        throw new Error(\"Develop rulings: input geometry must be a replicad.Face from a ruled \" +\n            \"loft; got \" +\n            (face && face.constructor ? face.constructor.name : typeof face));\n    }\n    if (!Number.isFinite(numRulings) || numRulings < 1) {\n        throw new Error(\"Develop rulings: numRulings must be a positive integer.\");\n    }\n    const n = Math.max(1, Math.floor(numRulings));\n    const boundaryN = Math.max(8, Math.floor(boundarySamples));\n    const { uMin, uMax, vMin, vMax } = face.UVBounds;\n    // IMPORTANT: replicad's face.pointOnSurface(u, v) takes NORMALISED\n    // parameters in [0, 1] (internally it does uMin + u*(uMax-uMin)), while\n    // face.UVBounds returns ABSOLUTE OCCT parameter values. Sampling with\n    // absolute values directly causes the ruling endpoints to land far\n    // outside the actual surface (apparent as rulings extending past the\n    // real face edges, especially on cones).\n    const uSpan = uMax - uMin;\n    const vSpan = vMax - vMin;\n    const sampleTuple = (uAbs, vAbs) => {\n        const uN = uSpan === 0 ? 0 : (uAbs - uMin) / uSpan;\n        const vN = vSpan === 0 ? 0 : (vAbs - vMin) / vSpan;\n        const p = face.pointOnSurface(uN, vN);\n        return [p.x, p.y, p.z];\n    };\n    // ── Step 2: Decide which parametric axis is the ruling direction ──────────\n    // An iso-curve sample at parameters (p0, pm, p1) is \"straight\" when the\n    // perpendicular distance from the midpoint to the chord is negligible\n    // relative to the chord length.\n    const STRAIGHT_TOL = 1e-4;\n    const isStraightAlong = (axis) => {\n        const cross = axis === \"U\" ? vMin + 0.5 * (vMax - vMin) : uMin + 0.5 * (uMax - uMin);\n        const a = axis === \"U\" ? uMin : vMin;\n        const b = axis === \"U\" ? uMax : vMax;\n        const get = (t) => axis === \"U\" ? sampleTuple(t, cross) : sampleTuple(cross, t);\n        const p0 = get(a);\n        const pm = get(0.5 * (a + b));\n        const p1 = get(b);\n        const dx = p1[0] - p0[0], dy = p1[1] - p0[1], dz = p1[2] - p0[2];\n        const chord = Math.hypot(dx, dy, dz);\n        if (chord === 0)\n            return false;\n        const tx = pm[0] - p0[0], ty = pm[1] - p0[1], tz = pm[2] - p0[2];\n        // |(p1-p0) × (pm-p0)| / |p1-p0| = perpendicular distance.\n        const cx = dy * tz - dz * ty;\n        const cy = dz * tx - dx * tz;\n        const cz = dx * ty - dy * tx;\n        const perp = Math.hypot(cx, cy, cz) / chord;\n        return perp / chord < STRAIGHT_TOL;\n    };\n    let axis;\n    if (rulingAxis === \"U\" || rulingAxis === \"V\") {\n        axis = rulingAxis;\n    }\n    else if (rulingAxis === \"auto\") {\n        const vStraight = isStraightAlong(\"V\");\n        const uStraight = isStraightAlong(\"U\");\n        if (vStraight)\n            axis = \"V\";\n        else if (uStraight)\n            axis = \"U\";\n        else\n            throw new Error(\"Develop rulings: auto-detect failed — surface is not straight along \" +\n                \"either parametric axis (it is not a ruled surface, or the trimmed \" +\n                \"region is curved on both axes). Override with rulingAxis: 'U' or 'V'.\");\n    }\n    else {\n        throw new Error('Develop rulings: rulingAxis must be \"auto\", \"U\", or \"V\"; got ' +\n            JSON.stringify(rulingAxis));\n    }\n    // ── Step 3: Sample the trimmed boundary in UV space ──────────────────────\n    // face.UVBounds is the bbox of the outerWire in UV space — it can be looser\n    // than the actual trimmed region whenever the wire is not axis-aligned in\n    // UV (common for lofts and any face on a periodic surface). A loft's\n    // underlying parametric surface also extends past the face — e.g. a conical\n    // loft continues toward its apex beyond the bottom circle. We follow\n    // face.outerWire() in UV space and use it to clip each ruling to the real\n    // trimmed region.\n    const outerWire = face.clone().outerWire();\n    const uvBoundary = [];\n    for (let i = 0; i < boundaryN; i++) {\n        const t = i / boundaryN;\n        const p3d = outerWire.pointAt(t);\n        const uv = face.uvCoordinates(p3d);\n        uvBoundary.push([uv[0], uv[1]]);\n    }\n    // axis === \"V\": rulings sweep V; cross-axis is U  → crossIdx=0, alongIdx=1\n    // axis === \"U\": rulings sweep U; cross-axis is V  → crossIdx=1, alongIdx=0\n    const crossIdx = axis === \"V\" ? 0 : 1;\n    const alongIdx = 1 - crossIdx;\n    let crossMinActual = Infinity;\n    let crossMaxActual = -Infinity;\n    for (const uv of uvBoundary) {\n        if (uv[crossIdx] < crossMinActual)\n            crossMinActual = uv[crossIdx];\n        if (uv[crossIdx] > crossMaxActual)\n            crossMaxActual = uv[crossIdx];\n    }\n    const crossSpan = crossMaxActual - crossMinActual;\n    if (!(crossSpan > 0)) {\n        throw new Error(\"Develop rulings: trimmed boundary has zero extent on the cross-axis.\");\n    }\n    // Intersect the iso-line \"cross-axis = crossParam\" with the closed UV\n    // polyline and return [alongMin, alongMax].\n    const rulingRange = (crossParam) => {\n        const hits = [];\n        const N = uvBoundary.length;\n        for (let j = 0; j < N; j++) {\n            const a = uvBoundary[j];\n            const b = uvBoundary[(j + 1) % N];\n            const aC = a[crossIdx];\n            const bC = b[crossIdx];\n            if (aC === bC)\n                continue;\n            // Skip seam wraparounds on periodic surfaces.\n            if (Math.abs(bC - aC) > 0.5 * crossSpan)\n                continue;\n            const straddles = (aC <= crossParam && bC > crossParam) ||\n                (bC <= crossParam && aC > crossParam);\n            if (!straddles)\n                continue;\n            const t = (crossParam - aC) / (bC - aC);\n            hits.push(a[alongIdx] + t * (b[alongIdx] - a[alongIdx]));\n        }\n        if (hits.length < 2) {\n            throw new Error(`Develop rulings: cross-axis ${axis === \"V\" ? \"U\" : \"V\"}=` +\n                `${crossParam.toFixed(4)} intersects the trimmed boundary at ` +\n                `${hits.length} point(s) (expected ≥2). Increase boundarySamples or ` +\n                `check for inner holes.`);\n        }\n        hits.sort((a, b) => a - b);\n        return [hits[0], hits[hits.length - 1]];\n    };\n    // ── Step 4: Build n+1 ruling edges, clipped to the outerWire polygon ─────\n    const rulings = [];\n    for (let i = 0; i <= n; i++) {\n        const t = i / n;\n        let crossParam = crossMinActual + t * crossSpan;\n        // Nudge the extremes a hair inward so the iso-line genuinely crosses\n        // the polygon (it may be tangent at the extreme cross values).\n        if (i === 0)\n            crossParam += crossSpan * 1e-6;\n        if (i === n)\n            crossParam -= crossSpan * 1e-6;\n        const [alongLow, alongHigh] = rulingRange(crossParam);\n        const startU = axis === \"V\" ? crossParam : alongLow;\n        const startV = axis === \"V\" ? alongLow : crossParam;\n        const endU = axis === \"V\" ? crossParam : alongHigh;\n        const endV = axis === \"V\" ? alongHigh : crossParam;\n        const start = sampleTuple(startU, startV);\n        const end = sampleTuple(endU, endV);\n        const edge = replicad.makeLine(start, end);\n        // The framework rejects bare Edges (see code.ts); wrap with assembleWire\n        // so each ruling round-trips as a Wire leaf.\n        const wire = replicad.assembleWire([edge]);\n        rulings.push(new Assembly({\n            geometry: wire,\n            color: \"#e07b00\",\n            tags: [\"ruling\"],\n        }));\n    }\n    return new Assembly({\n        geometry: rulings,\n        color: \"#e07b00\",\n        tags: [\"rulings\", \"ruling-axis:\" + axis],\n    });\n}\n"
                },
                {
                  "atomType": "Code",
                  "x": 0.90546875,
                  "y": 0.5785714285714285,
                  "uniqueID": "id-10960",
                  "ioValues": [
                    {
                      "name": "surface",
