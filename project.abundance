                },
                {
                  "atomType": "Code",
                  "x": 0.4453125,
                  "y": 0.5773809523809523,
                  "uniqueID": "id-10935",
                  "ioValues": [
                    {
                      "name": "surface",
                      "ioValue": "__GEOMETRY_INPUT__"
                    },
                    {
                      "name": "numRulings",
                      "ioValue": 50
                    },
                    {
                      "name": "rulingAxis",
                      "ioValue": "auto",
                      "currentEquation": "auto"
