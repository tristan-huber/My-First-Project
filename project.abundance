        {
          "atomType": "GitHubMolecule",
          "x": 0.45361328125000006,
          "y": 0.14375000000000002,
          "uniqueID": "id-4810",
          "name": "crv.BSpline",
          "ioValues": [
            {
              "name": "Points",
              "ioValue": "__GEOMETRY_INPUT__"
            },
            {
              "name": "close",
              "ioValue": false
            }
          ],
          "topLevel": false,
          "allAtoms": [
            {
              "atomType": "Output",
              "x": 0.98,
              "y": 0.5,
              "uniqueID": "id-4806",
              "ioValues": [
                {
                  "name": "number or geometry",
