            {
              "atomType": "Code",
              "x": 0.603515625,
              "y": 0.21428571428571427,
              "uniqueID": "id-3495",
              "ioValues": [
                {
                  "name": "shape",
                  "ioValue": "__GEOMETRY_INPUT__"
                },
